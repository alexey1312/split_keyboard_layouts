 #include "quantum.h"
+#include "crkbd_ruen/ruen.h"
+
+bool pre_process_record_kb(uint16_t keycode, keyrecord_t *record) {
+    if (!pre_process_record_ruen(keycode, record)) return false;
+    return pre_process_record_user(keycode, record);
+}
+
+void housekeeping_task_kb(void) {
+    housekeeping_task_ruen();
+    housekeeping_task_user();
+}
+
+// qmk-hid-host data type enum — must match host-side `DataType` in
+// https://github.com/zzeneg/qmk-hid-host/blob/main/src/data_type.rs
+// (_TIME = 0xAA, _VOLUME, _LAYOUT, ...). 0xB0 is a RuEnSync-specific
+// extension (upstream qmk-hid-host uses up to 0xAF) carrying a 4-byte
+// ASCII magic identifying the host OS — see
+// https://github.com/alexey1312/ruen-sync-mac.
+#define HID_HOST_LAYOUT  0xAC
+#define HID_HOST_OS_TYPE 0xB0
+
+void raw_hid_receive_kb(uint8_t *data, uint8_t length) {
+    if (length < 2) return;
+
+    if (data[0] == HID_HOST_LAYOUT) {
+        // data[1] is the index into the `layouts` array configured in
+        // qmk-hid-host.json. Our convention: index 0 = English, 1 = Russian.
+        lang_sync_to(data[1] == 0 ? LANG_EN : LANG_RU);
+        return;
+    }
+
+    if (data[0] == HID_HOST_OS_TYPE && length >= 5) {
+        // Honour only the first OS-type announcement per boot so a manual
+        // USER28 (LG_TG_MAC) override is not clobbered by routine daemon
+        // reconnects. The "no toggle after reflash" goal is still met:
+        // controller reboots on reflash, the flag resets, the next MAC\0
+        // lands.
+        static bool initial_os_msg_seen = false;
+        if (initial_os_msg_seen) return;
+        if (data[1] == 'M' && data[2] == 'A' && data[3] == 'C' && data[4] == 0) {
+            set_ruen_mac_layout(true);
+            initial_os_msg_seen = true;
+        }
+        // LNX\0 / WIN\0 / BSD\0 are deliberately not handled — RuEnSync is
+        // macOS-only, qmk-hid-host does not send 0xB0.
+    }
+}
 
